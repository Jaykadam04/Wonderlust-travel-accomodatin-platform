<% layout("/layouts/boilerplate") %>

<div class="row mt-5">
  <div class="col-md-8 offset-md-2">
    <h3 class="mb-4 text-center">Enter New Listings</h3>

    <form method="post" action="/listings" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" id="title" placeholder="Enter the title" class="form-control" required>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea required name="listing[description]" id="description" placeholder="Enter the description" class="form-control" rows="4"></textarea>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Image URL</label>
        <input type="text" name="listing[image.url]" id="image" placeholder="Enter the image URL" class="form-control">
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input required type="text" name="listing[price]" id="price" placeholder="Enter the price" class="form-control">
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input required type="text" name="listing[location]" id="location" placeholder="Enter the location" class="form-control">
      </div>

      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input required type="text" name="listing[country]" id="country" placeholder="Enter the country" class="form-control">
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-dark">Add Listing</button>
      </div>
    </form>
  </div>
</div>
